# Postgres
POSTGRES_USER=pastatop
POSTGRES_PASSWORD=pastatop
POSTGRES_DB=pastatop
# Host port for the dockerized Postgres. Override (e.g. 5433) if a local
# Postgres already occupies 5432; keep DATABASE_URL's port in sync.
POSTGRES_HOST_PORT=5432
DATABASE_URL=postgresql://pastatop:pastatop@localhost:5432/pastatop?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://pastatop:pastatop@localhost:5672
RABBITMQ_DEFAULT_USER=pastatop
RABBITMQ_DEFAULT_PASS=pastatop

# MinIO (S3-compatible)
MINIO_ROOT_USER=pastatop
MINIO_ROOT_PASSWORD=pastatoppastatop
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_BUCKET=photos
MINIO_ACCESS_KEY=pastatop
MINIO_SECRET_KEY=pastatoppastatop

# Auth
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=1d

# API
API_PORT=3000
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Worker
WORKER_ID=worker-1
